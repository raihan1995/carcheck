# DVLA Vehicle Enquiry Service (number plate → vehicle details)
# Get a free key: https://register-for-ves.driver-vehicle-licensing.api.gov.uk/
DVLA_API_KEY=

# MOT History API (OAuth2 – optional, for full MOT history)
# From your DVSA approval email:
MOT_CLIENT_ID=
MOT_CLIENT_SECRET=
MOT_API_KEY=
MOT_SCOPE_URL=https://tapi.dvsa.gov.uk/.default
MOT_TOKEN_URL=

# Umami analytics (optional – https://umami.is/)
# Get your website ID: https://cloud.umami.is/ → Add website → Settings
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Self-hosted? Set script URL:
# NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://your-umami.instance/script.js

# Optional: set to 1 to include error diagnostic (message + stack) in API responses for debugging
# API_CHECK_DEBUG=1

# Supabase (auth + user data)
# Dashboard: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy anon key also works if publishable key is not set:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL (password reset redirect, auth callbacks)
# NEXT_PUBLIC_APP_URL=https://revveal.co.uk
